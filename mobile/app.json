{
  "expo": {
    "name": "HomeAgent",
    "slug": "homeagent",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "homeagent",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.homeagent.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "HomeAgent uses speech recognition to transcribe your voice messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.homeagent.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://agreements-biblical-symantec-mixture.trycloudflare.com",
      "eas": {
        "projectId": "a975d8e6-c9bb-4bd9-97a7-b5d601d5fd03"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "HomeAgent needs access to your microphone for voice mode."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "HomeAgent needs your microphone for voice input.",
          "speechRecognitionPermission": "HomeAgent uses speech recognition to understand your voice."
        }
      ]
    ],
    "owner": "crazyhenry123"
  }
}
