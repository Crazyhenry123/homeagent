# ============================================================
# HomeAgent Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Cognito Auth ---
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# --- AgentCore ---
AGENTCORE_ORCHESTRATOR_AGENT_ID=
AGENTCORE_RUNTIME_ENDPOINT=
AGENTCORE_FAMILY_MEMORY_ID=
AGENTCORE_MEMBER_MEMORY_ID=
AGENTCORE_GATEWAY_ID=
HEALTH_MCP_ENDPOINT=
FAMILY_MCP_ENDPOINT=

# --- Local Dev Overrides ---
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
S3_ENDPOINT=http://minio:9000
S3_PRESIGNED_ENDPOINT=http://localhost:9000
